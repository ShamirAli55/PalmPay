# ─────────────────────────────────────────────────────────────────────────────
# PalmPay Frontend — Environment Variables
# Copy this file to .env and fill in the values before running the dev server.
# All variables exposed to the browser MUST be prefixed with VITE_.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Clerk Authentication
# Publishable key — obtained from the Clerk Dashboard → API Keys
# Must start with pk_test_ (development) or pk_live_ (production)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
