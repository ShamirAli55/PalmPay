# ─────────────────────────────────────────────────────────────────────────────
# PalmPay Backend — Environment Variables
# Copy this file to .env and fill in the values before running the server.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/palmpay_wallet?appName=Cluster0

# Palm Auth microservice base URL (Python / FastAPI)
# Change to the host/port where main.py is running
PALM_AUTH_URL=http://localhost:8000

# Clerk secret key — obtained from the Clerk Dashboard → API Keys
# Must start with sk_test_ (development) or sk_live_ (production)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here


